# Copy this file to .env and replace placeholder values.
# Never commit real passwords, tokens, or SMTP credentials.

# Runtime
NODE_ENV=development
PORT=3000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=recipe_shelter
DB_USER=root
DB_PASSWORD=your_database_password
DB_CONNECTION_LIMIT=10
# Optional, dedicated database used only by npm run test:mysql.
# Must be different from DB_NAME and contain the word "test".
TEST_DB_NAME=recipe_shelter_test

# Auth
JWT_SECRET=your_long_random_jwt_secret
AUTH_APP_JWT_AUDIENCE=recipe-shelter-app
AUTH_APP_JWT_EXPIRES_IN=7d
AUTH_APP_SESSION_COOKIE_NAME=rs_app_session
AUTH_APP_SESSION_COOKIE_MAX_AGE_MS=604800000
AUTH_ADMIN_JWT_AUDIENCE=recipe-shelter-admin
AUTH_ADMIN_JWT_EXPIRES_IN=8h
AUTH_ADMIN_SESSION_COOKIE_NAME=rs_admin_session
AUTH_ADMIN_SESSION_COOKIE_MAX_AGE_MS=28800000
AUTH_SESSION_COOKIE_SAME_SITE=lax
AUTH_SESSION_COOKIE_SECURE=false
# AUTH_SESSION_COOKIE_DOMAIN=.recipe-shelter.fr
# Staff MFA: WebAuthn/passkeys or FIDO2 security keys. The origin must exactly match the frontend origin.
AUTH_STAFF_WEBAUTHN_ORIGIN=http://localhost:4200
AUTH_STAFF_WEBAUTHN_RP_ID=localhost
AUTH_STAFF_WEBAUTHN_RP_NAME=Recipe Shelter Staff
AUTH_STAFF_MFA_CHALLENGE_TTL_MS=300000
AUTH_STAFF_REAUTHENTICATION_MAX_AGE_MS=300000
BCRYPT_COST=12
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_MS=900000

# First SuperAdmin bootstrap invitation
BOOTSTRAP_SUPER_ADMIN_INVITATION_TTL_MINUTES=30

# Staff invitation created from the administration API (24 hours by default)
STAFF_INVITATION_TTL_MINUTES=1440

# HTTP / Frontend
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
FRONTEND_BASE_URL=http://localhost:4200

# Recipe cover image storage (local by default; allowed values: local, s3)
IMAGE_STORAGE_DRIVER=local
IMAGE_LOCAL_ROOT=./var/uploads
IMAGE_PUBLIC_BASE_URL=http://localhost:3000/media
# Required only with IMAGE_STORAGE_DRIVER=s3 (Cloudflare R2 is S3-compatible)
IMAGE_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
IMAGE_S3_REGION=auto
IMAGE_S3_BUCKET=recipe-shelter
IMAGE_S3_ACCESS_KEY_ID=
IMAGE_S3_SECRET_ACCESS_KEY=

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=no-reply@recipe-shelter.local

# Contact
CONTACT_RECIPIENT_EMAIL=contact@recipe-shelter.local
