# Copy this file to .env and replace placeholder values.
# Never commit real passwords, tokens, or SMTP credentials.

# Runtime
NODE_ENV=development
PORT=3000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=recipe_shelter
DB_USER=root
DB_PASSWORD=your_database_password
DB_CONNECTION_LIMIT=10
# Optional, dedicated database used only by npm run test:mysql.
# Must be different from DB_NAME and contain the word "test".
TEST_DB_NAME=recipe_shelter_test

# Auth
JWT_SECRET=your_long_random_jwt_secret
JWT_EXPIRES_IN=7d
AUTH_SESSION_COOKIE_NAME=rs_session
AUTH_SESSION_COOKIE_SAME_SITE=lax
AUTH_SESSION_COOKIE_SECURE=false
# AUTH_SESSION_COOKIE_DOMAIN=.recipe-shelter.fr
# AUTH_SESSION_COOKIE_MAX_AGE_MS=604800000
BCRYPT_COST=12
AUTH_DEFAULT_ROLE_NAME=user
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_WINDOW_MS=900000

# HTTP / Frontend
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
FRONTEND_BASE_URL=http://localhost:4200

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=no-reply@recipe-shelter.local

# Contact
CONTACT_RECIPIENT_EMAIL=contact@recipe-shelter.local
