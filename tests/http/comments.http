# ============================================
# Comments
# ============================================

@baseUrl = http://localhost:3000/api/v1
@sessionCookie = PASTE_RS_APP_SESSION_COOKIE_HERE
@recipeId = 1
@commentId = 1
@parentCommentId = 1
@recipeSlug = cake-marbre-maison

### Recipe comments - public
GET {{baseUrl}}/recipes/{{recipeId}}/comments

# Expected response shape:
# [
#   {
#     "id": 1,
#     "recipeId": 1,
#     "author": {
#       "id": 10,
#       "username": "alice"
#     },
#     "parentCommentId": null,
#     "moderatedAt": null,
#     "deletedAt": null,
#     "rating": 5,
#     "comment": "Super recette, facile à suivre.",
#     "createdAt": "2026-05-10T10:00:00.000Z",
#     "updatedAt": "2026-05-10T10:00:00.000Z",
#     "children": [
#       {
#         "id": 2,
#         "recipeId": 1,
#         "author": {
#           "id": 11,
#           "username": "bob"
#         },
#         "parentCommentId": 1,
#         "moderatedAt": null,
#         "deletedAt": "2026-05-10T10:12:00.000Z",
#         "rating": null,
#         "comment": "Commentaire supprimé par son auteur.",
#         "createdAt": "2026-05-10T10:05:00.000Z",
#         "updatedAt": "2026-05-10T10:12:00.000Z",
#         "children": []
#       },
#       {
#         "id": 3,
#         "recipeId": 1,
#         "author": {
#           "id": 12,
#           "username": "charlie"
#         },
#         "parentCommentId": 1,
#         "moderatedAt": "2026-05-10T10:20:00.000Z",
#         "deletedAt": null,
#         "rating": null,
#         "comment": "Ce commentaire a été masqué par la modération.",
#         "createdAt": "2026-05-10T10:15:00.000Z",
#         "updatedAt": "2026-05-10T10:20:00.000Z",
#         "children": []
#       }
#     ]
#   }
# ]

### Published recipe detail with comment tree - public
GET {{baseUrl}}/recipes/{{recipeSlug}}

# Expected comments shape in recipe detail:
# {
#   "author": {
#     "id": 12,
#     "username": "arthur"
#   },
#   "commentsCount": 4,
