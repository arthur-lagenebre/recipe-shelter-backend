### Recipe comments - bad recipe id
GET {{baseUrl}}/recipes/abc/comments

### Create root comment with rating
POST {{baseUrl}}/recipes/{{recipeId}}/comments
Content-Type: application/json
Cookie: rs_app_session={{sessionCookie}}

{
  "rating": 5,
  "comment": "Super recette, facile a suivre."
}

### Create reply without rating
POST {{baseUrl}}/recipes/{{recipeId}}/comments
Content-Type: application/json
Cookie: rs_app_session={{sessionCookie}}

{
  "parentCommentId": {{parentCommentId}},
  "comment": "Merci pour l'astuce."
}

### Create comment - missing auth
POST {{baseUrl}}/recipes/{{recipeId}}/comments
Content-Type: application/json

{
  "rating": 4,
  "comment": "Je teste sans token."
}

### Create comment - missing comment
POST {{baseUrl}}/recipes/{{recipeId}}/comments
Content-Type: application/json
Cookie: rs_app_session={{sessionCookie}}

{
  "rating": 5
}

### Create comment - invalid rating
POST {{baseUrl}}/recipes/{{recipeId}}/comments
Content-Type: application/json
Cookie: rs_app_session={{sessionCookie}}

{
  "rating": 6,
  "comment": "Note invalide."
}

### Create reply - rating not allowed
POST {{baseUrl}}/recipes/{{recipeId}}/comments
Content-Type: application/json
Cookie: rs_app_session={{sessionCookie}}

{
  "parentCommentId": {{parentCommentId}},
  "rating": 4,
  "comment": "Une reponse ne peut pas noter la recette."
}

### Create nested reply - not allowed
POST {{baseUrl}}/recipes/{{recipeId}}/comments
Content-Type: application/json
Cookie: rs_app_session={{sessionCookie}}

{
  "parentCommentId": {{parentCommentId}},
  "comment": "Une reponse a une reponse doit etre refusee."
}

### Update my comment
PATCH {{baseUrl}}/comments/{{commentId}}
Content-Type: application/json
Cookie: rs_app_session={{sessionCookie}}

{
  "rating": 4,
  "comment": "Commentaire mis a jour."
}

### Update my comment - remove rating
PATCH {{baseUrl}}/comments/{{commentId}}
Content-Type: application/json
Cookie: rs_app_session={{sessionCookie}}

{
  "rating": null,
  "comment": "Commentaire mis a jour sans note."
}

### Update comment - bad comment id
PATCH {{baseUrl}}/comments/abc
Content-Type: application/json
Cookie: rs_app_session={{sessionCookie}}

{
  "rating": 4,
  "comment": "Identifiant invalide."
}

### Update comment - missing auth
PATCH {{baseUrl}}/comments/{{commentId}}
Content-Type: application/json

{
  "rating": 4,
  "comment": "Je teste sans token."
}

### Delete my comment - soft delete
DELETE {{baseUrl}}/comments/{{commentId}}
Cookie: rs_app_session={{sessionCookie}}

### Delete comment - missing auth
DELETE {{baseUrl}}/comments/{{commentId}}
