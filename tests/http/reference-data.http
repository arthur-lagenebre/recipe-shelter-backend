# ============================================
# Reference data
# ============================================

@baseUrl = http://localhost:3000/api/v1
@sessionCookie = PASTE_RS_APP_SESSION_COOKIE_HERE
@categoryId = 1
@equipmentId = 1
@ingredientId = 1
@tagId = 1

### Categories
GET {{baseUrl}}/categories
Cookie: rs_app_session={{sessionCookie}}

### Category by id
GET {{baseUrl}}/categories/{{categoryId}}
Cookie: rs_app_session={{sessionCookie}}

### Equipments
GET {{baseUrl}}/equipments
Cookie: rs_app_session={{sessionCookie}}

### Equipment by id
GET {{baseUrl}}/equipments/{{equipmentId}}
Cookie: rs_app_session={{sessionCookie}}

### Ingredients
GET {{baseUrl}}/ingredients
Cookie: rs_app_session={{sessionCookie}}

### Ingredient by id
GET {{baseUrl}}/ingredients/{{ingredientId}}
Cookie: rs_app_session={{sessionCookie}}

### Tags
GET {{baseUrl}}/tags
Cookie: rs_app_session={{sessionCookie}}

# Expected response items include:
# {
#   "id": 1,
#   "name": "Végétarien",
#   "slug": "vegetarien",
#   "group": {
#     "id": 1,
#     "name": "Régimes alimentaires",
#     "slug": "regimes-alimentaires",
#     "sortOrder": 1
#   }
# }

### Tag by id
GET {{baseUrl}}/tags/{{tagId}}
Cookie: rs_app_session={{sessionCookie}}
