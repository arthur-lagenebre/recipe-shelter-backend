# ============================================
# Recipes
# ============================================

@baseUrl = http://localhost:3000
@jwt = PASTE_JWT_HERE
@recipeId = 1
@recipeSlug = cake-marbre-maison

### Published recipes - public
GET {{baseUrl}}/recipes

### Published recipes - public paginated
GET {{baseUrl}}/recipes?page=1&limit=12

### Published recipes - search by title
GET {{baseUrl}}/recipes?q=porc&page=1&limit=12

### Published recipes - filter by category
GET {{baseUrl}}/recipes?categoryId=3&page=1&limit=12

### Published recipes - search by title and category
GET {{baseUrl}}/recipes?q=porc&categoryId=3&page=2&limit=12

### Published recipes - legacy search route
GET {{baseUrl}}/recipes/search?q=porc&categoryId=3&page=1&limit=12

### Recent published recipes - public
GET {{baseUrl}}/recipes/recent?limit=12

### Top-rated published recipes - public
GET {{baseUrl}}/recipes/top-rated?limit=12

### Top-rated published recipes - with optional auth, includes isFavorite for current user
GET {{baseUrl}}/recipes/top-rated?limit=20
Authorization: Bearer {{jwt}}

### Published recipes - filter by tags
GET {{baseUrl}}/recipes/search?tagIds=1,2

### Published recipes - filter by ingredients
GET {{baseUrl}}/recipes/search?ingredientIds=18,103

### Published recipes - filter by max total time
GET {{baseUrl}}/recipes/search?maxTotalTimeMinutes=45

### Published recipes - search with all filters
GET {{baseUrl}}/recipes/search?q=porc&categoryId=3&tagIds=1,2&ingredientIds=18,103&maxTotalTimeMinutes=60

### Published recipes - with optional auth, includes isFavorite for current user
GET {{baseUrl}}/recipes
Authorization: Bearer {{jwt}}

### Published recipe detail by slug
GET {{baseUrl}}/recipes/{{recipeSlug}}
Authorization: Bearer {{jwt}}

