# ============================================
# Auth
# ============================================

@baseUrl = http://localhost:3000/api/v1
@mail = test@example.com
@username = testuser
@password = Password123!
@newPassword = NewPassword123!
@resetToken = PASTE_RESET_TOKEN_HERE
@validationToken = PASTE_VALIDATION_TOKEN_HERE
@sessionCookie = PASTE_RS_APP_SESSION_COOKIE_HERE
@adminMail = staff@example.com
@adminMfaCode = 123456
@adminSessionCookie = PASTE_RS_ADMIN_SESSION_COOKIE_HERE

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "mail": "{{mail}}",
  "username": "{{username}}",
  "password": "{{password}}"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "mail": "{{mail}}",
  "password": "{{password}}"
}

### Validate email
POST {{baseUrl}}/auth/validate-email
Content-Type: application/json

{
  "token": "{{validationToken}}"
}

### Resend validation email
POST {{baseUrl}}/auth/resend-validation-email
Content-Type: application/json

{
  "mail": "{{mail}}"
}

### Auth me
GET {{baseUrl}}/auth/me
Cookie: rs_app_session={{sessionCookie}}

### Logout
POST {{baseUrl}}/auth/logout
Cookie: rs_app_session={{sessionCookie}}

### Staff login (password + TOTP)
POST {{baseUrl}}/admin/auth/login
Content-Type: application/json

{
  "mail": "{{adminMail}}",
  "password": "{{password}}",
  "mfaCode": "{{adminMfaCode}}"
}

### Staff auth me
GET {{baseUrl}}/admin/auth/me
Cookie: rs_admin_session={{adminSessionCookie}}

### Staff logout
POST {{baseUrl}}/admin/auth/logout
Cookie: rs_admin_session={{adminSessionCookie}}

### Forgot password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "mail": "{{mail}}"
}

### Forgot password - missing email
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "mail": ""
}

### Reset password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "{{newPassword}}"
}

### Reset password - weak password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "123"
}
