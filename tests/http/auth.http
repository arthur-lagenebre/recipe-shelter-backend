# ============================================
# Auth
# ============================================

@baseUrl = http://localhost:3000/api/v1
@mail = test@example.com
@username = testuser
@password = Password123!
@newPassword = NewPassword123!
@resetToken = PASTE_RESET_TOKEN_HERE
@validationToken = PASTE_VALIDATION_TOKEN_HERE
@sessionCookie = PASTE_RS_APP_SESSION_COOKIE_HERE
@adminMail = staff@example.com
@staffInvitationToken = PASTE_STAFF_INVITATION_TOKEN_HERE
@staffMfaFlowId = PASTE_STAFF_MFA_FLOW_ID_HERE
@staffLoginFlowId = PASTE_STAFF_LOGIN_FLOW_ID_HERE
@adminSessionCookie = PASTE_RS_ADMIN_SESSION_COOKIE_HERE

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "mail": "{{mail}}",
  "username": "{{username}}",
  "password": "{{password}}"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "mail": "{{mail}}",
  "password": "{{password}}"
}

### Validate email
POST {{baseUrl}}/auth/validate-email
Content-Type: application/json

{
  "token": "{{validationToken}}"
}

### Resend validation email
POST {{baseUrl}}/auth/resend-validation-email
Content-Type: application/json

{
  "mail": "{{mail}}"
}

### Auth me
GET {{baseUrl}}/auth/me
Cookie: rs_app_session={{sessionCookie}}

### Logout
POST {{baseUrl}}/auth/logout
Cookie: rs_app_session={{sessionCookie}}

### Staff MFA enrollment options
POST {{baseUrl}}/admin/auth/mfa/enrollment/options
Content-Type: application/json

{
  "invitationToken": "{{staffInvitationToken}}"
}

### Staff MFA enrollment verification (replace credential with startRegistration() output)
POST {{baseUrl}}/admin/auth/mfa/enrollment/verify
Content-Type: application/json

{
  "flowId": "{{staffMfaFlowId}}",
  "invitationToken": "{{staffInvitationToken}}",
  "password": "{{password}}",
  "credential": {}
}

### Staff login options (password first factor)
POST {{baseUrl}}/admin/auth/login/options
Content-Type: application/json

{
  "mail": "{{adminMail}}",
  "password": "{{password}}"
}

### Staff login verification (replace credential with startAuthentication() output)
POST {{baseUrl}}/admin/auth/login/verify
Content-Type: application/json

{
  "flowId": "{{staffLoginFlowId}}",
  "credential": {}
}

### Staff auth me
GET {{baseUrl}}/admin/auth/me
Cookie: rs_admin_session={{adminSessionCookie}}

### Staff logout
POST {{baseUrl}}/admin/auth/logout
Cookie: rs_admin_session={{adminSessionCookie}}

### Forgot password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "mail": "{{mail}}"
}

### Forgot password - missing email
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "mail": ""
}

### Reset password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "{{newPassword}}"
}

### Reset password - weak password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "123"
}
