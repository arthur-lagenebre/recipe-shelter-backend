# ============================================
# Admin comments
# ============================================

@baseUrl = http://localhost:3000/api/v1
@adminSessionCookie = PASTE_ADMIN_RS_SESSION_COOKIE_HERE
@commentId = 1

### Moderated comments
GET {{baseUrl}}/admin/comments/moderated
Cookie: rs_session={{adminSessionCookie}}

### Moderated comments count
GET {{baseUrl}}/admin/comments/moderated/count
Cookie: rs_session={{adminSessionCookie}}

### Soft deleted comments
GET {{baseUrl}}/admin/comments/soft-deleted
Cookie: rs_session={{adminSessionCookie}}

### Soft deleted comments count
GET {{baseUrl}}/admin/comments/soft-deleted/count
Cookie: rs_session={{adminSessionCookie}}

### Hide comment as admin
POST {{baseUrl}}/admin/comments/{{commentId}}/hide
Cookie: rs_session={{adminSessionCookie}}

### Remove moderation from comment as admin
POST {{baseUrl}}/admin/comments/{{commentId}}/unmoderate
Cookie: rs_session={{adminSessionCookie}}

### Restore soft deleted comment as admin
POST {{baseUrl}}/admin/comments/{{commentId}}/restore
Cookie: rs_session={{adminSessionCookie}}

### Update comment as admin
PATCH {{baseUrl}}/admin/comments/{{commentId}}
Content-Type: application/json
Cookie: rs_session={{adminSessionCookie}}

{
  "rating": null,
  "comment": "Commentaire modifie par un administrateur."
}

### Update comment as admin - invalid rating
PATCH {{baseUrl}}/admin/comments/{{commentId}}
Content-Type: application/json
Cookie: rs_session={{adminSessionCookie}}

{
  "rating": 6,
  "comment": "Note invalide."
}

### Delete comment as admin - hard delete
DELETE {{baseUrl}}/admin/comments/{{commentId}}
Cookie: rs_session={{adminSessionCookie}}
