# ============================================
# Admin users
# ============================================

@baseUrl = http://localhost:3000
@adminJwt = PASTE_ADMIN_JWT_HERE
@userId = 2

### Banned users
GET {{baseUrl}}/admin/users/banned
Authorization: Bearer {{adminJwt}}

### Banned users count
GET {{baseUrl}}/admin/users/banned/count
Authorization: Bearer {{adminJwt}}

### Admin user profile
GET {{baseUrl}}/admin/users/{{userId}}
Authorization: Bearer {{adminJwt}}

### Ban user
POST {{baseUrl}}/admin/users/{{userId}}/ban
Authorization: Bearer {{adminJwt}}
Content-Type: application/json

{
  "reason": "Repeated abuse of the platform rules."
}

### Unban user
POST {{baseUrl}}/admin/users/{{userId}}/unban
Authorization: Bearer {{adminJwt}}
Content-Type: application/json

{
  "reason": "Appeal accepted after moderation review."
}
