# ============================================
# Recipe Shelter API - Test Flow
# ============================================
#
# Order of execution:
#
# 1. Register a user
#    → creates account
#
# 2. Login
#    → copy the JWT into @jwt
#
# 3. Test /auth/me
#    → verifies authentication works
#
# 4. Forgot password
#    → triggers reset email (check server console)
#    → copy token from resetUrl into @resetToken
#
# 5. Reset password
#    → use @resetToken and @newPassword
#
# 6. Login with new password
#    → should succeed
#
# 7. Login with old password
#    → should fail
#
# Notes:
# - JWT (@jwt) is used for authenticated routes
# - Reset token (@resetToken) is temporary and single-use
# - Tokens are printed in console (ConsoleMailer)
#
# ============================================

@baseUrl = http://localhost:3000
@mail = test@example.com
@username = testuser
@password = Password123!
@newPassword = NewPassword123!
@resetToken = PASTE_RESET_TOKEN_HERE
@jwt = PASTE_JWT_HERE

### Home
GET {{baseUrl}}/

### Health
GET {{baseUrl}}/health

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "mail": "{{mail}}",
  "username": "{{username}}",
  "password": "{{password}}"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "mail": "{{mail}}",
  "password": "{{password}}"
}

### Me
GET {{baseUrl}}/auth/me
Authorization: Bearer {{jwt}}

### Forgot password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "mail": "{{mail}}"
}

### Forgot password - unknown email
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "mail": "unknown@example.com"
}

### Forgot password - missing email
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "mail": ""
}

### Reset password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "{{newPassword}}"
}

### Reset password - missing token
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "",
  "password": "{{newPassword}}"
}

### Reset password - weak password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "123"
}

### Login with new password
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "mail": "{{mail}}",
  "password": "{{newPassword}}"
}

### Login with old password should fail after reset
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "mail": "{{mail}}",
  "password": "{{password}}"
}

### Reset password - reuse same token should fail
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "AnotherPassword123!"
}

### users/Me
GET http://localhost:3000/users/me
Authorization: Bearer {{jwt}}

### Update email
PATCH http://localhost:3000/users/email
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "newEmail": "new-test@example.com",
  "currentPassword": "AnotherPassword123!"
}

### Update email - reset
PATCH http://localhost:3000/users/email
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "newEmail": "{{mail}}",
  "currentPassword": "AnotherPassword123!"
}

### Update password
PATCH http://localhost:3000/users/password
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "currentPassword": "AnotherPassword123!",
  "newPassword": "{{password}}"
}

### Update email - missing password
PATCH http://localhost:3000/users/email
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "newEmail": "test@example.com",
  "currentPassword": ""
}

### Update password - wrong current password
PATCH http://localhost:3000/users/password
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "currentPassword": "WrongPassword123!",
  "newPassword": "Password1234!"
}

### Create recipe draft - minimal
POST {{baseUrl}}/recipes/create
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Tarte aux pommes"
}

### Get recipe draft - minimal
GET {{baseUrl}}/recipes/2
Authorization: Bearer {{jwt}}

### Get my recipes
GET {{baseUrl}}/recipes/me
Authorization: Bearer {{jwt}}

### Create recipe draft - full body
POST {{baseUrl}}/recipes/create
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Cake marbre maison",
  "categoryId": 2,
  "description": "Version brouillon pour test HTTP",
  "prepTimeMinutes": 15,
  "restTimeMinutes": null,
  "cookTimeMinutes": 45,
  "servings": 6,
  "ingredients": [
    {
      "ingredientId": 18,
      "quantity": 200,
      "unit": "g",
      "note": "Tamisee"
    },
    {
      "ingredientId": 103,
      "quantity": 3,
      "unit": "piece"
    }
  ],
  "steps": [
    {
      "description": "Prechauffer le four a 180 degres."
    },
    {
      "description": "Melanger les ingredients puis verser dans un moule."
    }
  ],
  "utensils": [
    {
      "utensilId": 1
    },
    {
      "utensilId": 2
    }
  ]
}

### Create recipe draft - missing auth
POST {{baseUrl}}/recipes/create
Content-Type: application/json

{
  "title": "Soupe du soir"
}

### Create recipe draft - missing title
POST {{baseUrl}}/recipes/create
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "description": "Pas de titre"
}

### Create recipe draft - title too short
POST {{baseUrl}}/recipes/create
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Cake"
}

### Create recipe draft - invalid servings type
POST {{baseUrl}}/recipes/create
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Cake au citron",
  "servings": "6"
}

### Update recipe draft
PATCH {{baseUrl}}/recipes/1
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Cake marbre maison v2",
  "description": "Version mise a jour pour test HTTP",
  "ingredients": [
    {
      "ingredientId": 18,
      "quantity": 250,
      "unit": "g"
    }
  ],
  "steps": [
    {
      "description": "Prechauffer le four."
    },
    {
      "description": "Cuire pendant 45 minutes."
    }
  ],
  "utensils": [
    {
      "utensilId": 1
    }
  ]
}

### Submit recipe draft
PATCH {{baseUrl}}/recipes/1/submit
Content-Type: application/json
Authorization: Bearer {{jwt}}
