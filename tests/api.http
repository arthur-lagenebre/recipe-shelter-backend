# ============================================
# Recipe Shelter API - HTTP smoke tests
# ============================================
#
# How to use:
# 1. Start the API on http://localhost:3000.
# 2. Register or login, then copy the returned JWT into @jwt.
# 3. For admin routes, copy an admin JWT into @adminJwt.
# 4. Update @recipeId and @recipeSlug with values from your database/responses.
#
# Notes:
# - Authenticated routes use Authorization: Bearer {{jwt}}.
# - Admin routes require a token whose payload has roleId === 1.
# - Password reset tokens are printed by ConsoleMailer in the server logs.
#
# ============================================

@baseUrl = http://localhost:3000
@mail = test@example.com
@username = testuser
@password = Password123!
@newPassword = NewPassword123!
@resetToken = PASTE_RESET_TOKEN_HERE
@jwt = PASTE_JWT_HERE
@adminJwt = PASTE_ADMIN_JWT_HERE
@recipeId = 1
@recipeSlug = cake-marbre-maison
@categoryId = 1
@equipmentId = 1
@ingredientId = 1
@tagId = 1

### Unknown route - should return 404 ROUTE_NOT_FOUND
GET {{baseUrl}}/

# ============================================
# Auth
# ============================================

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "mail": "{{mail}}",
  "username": "{{username}}",
  "password": "{{password}}"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "mail": "{{mail}}",
  "password": "{{password}}"
}

### Auth me
GET {{baseUrl}}/auth/me
Authorization: Bearer {{jwt}}

### Forgot password
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "mail": "{{mail}}"
}

### Forgot password - missing email
POST {{baseUrl}}/auth/forgot-password
Content-Type: application/json

{
  "mail": ""
}

### Reset password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "{{newPassword}}"
}

### Reset password - weak password
POST {{baseUrl}}/auth/reset-password
Content-Type: application/json

{
  "token": "{{resetToken}}",
  "password": "123"
}

# ============================================
# Users
# ============================================

### User profile
GET {{baseUrl}}/users/me
Authorization: Bearer {{jwt}}

### Update email
PATCH {{baseUrl}}/users/me/email
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "newEmail": "new-test@example.com",
  "currentPassword": "{{password}}"
}

### Update username
PATCH {{baseUrl}}/users/me/username
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "newUsername": "newtestuser",
  "currentPassword": "{{password}}"
}

### Update password
PATCH {{baseUrl}}/users/me/password
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "currentPassword": "{{password}}",
  "newPassword": "{{newPassword}}"
}

### Update password - wrong current password
PATCH {{baseUrl}}/users/me/password
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "currentPassword": "WrongPassword123!",
  "newPassword": "Password1234!"
}

# ============================================
# Recipes
# ============================================

### Published recipes - public
GET {{baseUrl}}/recipes

### Published recipes - with optional auth, includes isFavorite for current user
GET {{baseUrl}}/recipes
Authorization: Bearer {{jwt}}

### Published recipe detail by slug
GET {{baseUrl}}/recipes/{{recipeSlug}}
Authorization: Bearer {{jwt}}

### My recipes
GET {{baseUrl}}/recipes/me
Authorization: Bearer {{jwt}}

### Create recipe draft - minimal
POST {{baseUrl}}/recipes
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Tarte aux pommes"
}

### Create recipe draft - full body
POST {{baseUrl}}/recipes
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Cake marbre maison",
  "categoryId": 2,
  "description": "Version brouillon pour test HTTP",
  "coverImageUrl": null,
  "prepTimeMinutes": 15,
  "restTimeMinutes": null,
  "cookTimeMinutes": 45,
  "servings": 6,
  "tagIds": [1, 2],
  "ingredients": [
    {
      "ingredientId": 18,
      "quantity": 200,
      "unit": "g",
      "note": "Tamisee"
    },
    {
      "ingredientId": 103,
      "quantity": 3,
      "unit": "piece"
    }
  ],
  "steps": [
    {
      "description": "Prechauffer le four a 180 degres."
    },
    {
      "description": "Melanger les ingredients puis verser dans un moule."
    }
  ],
  "utensils": [
    {
      "utensilId": 1
    },
    {
      "utensilId": 2
    }
  ]
}

### Create recipe draft - missing auth
POST {{baseUrl}}/recipes
Content-Type: application/json

{
  "title": "Soupe du soir"
}

### Create recipe draft - missing title
POST {{baseUrl}}/recipes
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "description": "Pas de titre"
}

### Create recipe draft - title too short
POST {{baseUrl}}/recipes
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Cake"
}

### Create recipe draft - invalid servings type
POST {{baseUrl}}/recipes
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Cake au citron",
  "servings": "6"
}

### Get my recipe by id
GET {{baseUrl}}/recipes/me/{{recipeId}}
Authorization: Bearer {{jwt}}

### Update recipe draft
PUT {{baseUrl}}/recipes/me/{{recipeId}}
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "title": "Cake marbre maison v2",
  "description": "Version mise a jour pour test HTTP",
  "ingredients": [
    {
      "ingredientId": 18,
      "quantity": 250,
      "unit": "g"
    }
  ],
  "steps": [
    {
      "description": "Prechauffer le four."
    },
    {
      "description": "Cuire pendant 45 minutes."
    }
  ],
  "utensils": [
    {
      "utensilId": 1
    }
  ]
}

### Submit recipe draft
POST {{baseUrl}}/recipes/me/{{recipeId}}/submit
Authorization: Bearer {{jwt}}

### Archive my recipe
POST {{baseUrl}}/recipes/me/{{recipeId}}/archive
Authorization: Bearer {{jwt}}

# ============================================
# Favorites
# ============================================

### Add favorite
POST {{baseUrl}}/favorites/create
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "userId": 1,
  "recipeId": {{recipeId}}
}

### My favorite recipes
GET {{baseUrl}}/favorites/me
Authorization: Bearer {{jwt}}

### Remove favorite
POST {{baseUrl}}/favorites/delete
Content-Type: application/json
Authorization: Bearer {{jwt}}

{
  "userId": 1,
  "recipeId": {{recipeId}}
}

# ============================================
# Reference data
# ============================================

### Categories
GET {{baseUrl}}/categories
Authorization: Bearer {{jwt}}

### Category by id
GET {{baseUrl}}/categories/{{categoryId}}
Authorization: Bearer {{jwt}}

### Equipments
GET {{baseUrl}}/equipments
Authorization: Bearer {{jwt}}

### Equipment by id
GET {{baseUrl}}/equipments/{{equipmentId}}
Authorization: Bearer {{jwt}}

### Ingredients
GET {{baseUrl}}/ingredients
Authorization: Bearer {{jwt}}

### Ingredient by id
GET {{baseUrl}}/ingredients/{{ingredientId}}
Authorization: Bearer {{jwt}}

### Tags
GET {{baseUrl}}/tags
Authorization: Bearer {{jwt}}

### Tag by id
GET {{baseUrl}}/tags/{{tagId}}
Authorization: Bearer {{jwt}}

# ============================================
# Admin recipes
# ============================================

### Pending recipes
GET {{baseUrl}}/admin/recipes
Authorization: Bearer {{adminJwt}}

### Pending recipes count
GET {{baseUrl}}/admin/recipes/count
Authorization: Bearer {{adminJwt}}

### Admin recipe detail
GET {{baseUrl}}/admin/recipes/{{recipeId}}
Authorization: Bearer {{adminJwt}}

### Approve recipe
POST {{baseUrl}}/admin/recipes/{{recipeId}}/approve
Authorization: Bearer {{adminJwt}}

### Reject recipe
POST {{baseUrl}}/admin/recipes/{{recipeId}}/reject
Content-Type: application/json
Authorization: Bearer {{adminJwt}}

{
  "rejectionReason": "La recette doit etre completee avant publication."
}

### Archive recipe as admin
POST {{baseUrl}}/admin/recipes/{{recipeId}}/archive
Authorization: Bearer {{adminJwt}}

### Delete recipe as admin
DELETE {{baseUrl}}/admin/recipes/{{recipeId}}
Authorization: Bearer {{adminJwt}}

# ============================================
# Health
# ============================================

### Health live
GET {{baseUrl}}/health/live
Authorization: Bearer {{adminJwt}}

### Health ready
GET {{baseUrl}}/health/ready
Authorization: Bearer {{adminJwt}}

### Health
GET {{baseUrl}}/health
Authorization: Bearer {{adminJwt}}
