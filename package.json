{
  "name": "recipe-shelter-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "start": "node dist/server.js",
    "db:reset": "mysql -u root -p < database/reset.sql",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.18.2"
  }
}
