{
  "info": {
    "name": "Recipe Shelter - Health",
    "description": "Postman collection for admin-only health routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "adminSessionCookie",
      "value": "PASTE_RS_ADMIN_SESSION_COOKIE_HERE"
    }
  ],
  "item": [
    {
      "name": "Health live",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health/live",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "health",
            "live"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },
    {
      "name": "Health ready",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health/ready",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "health",
            "ready"
          ]
        }
      }
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "health"
          ]
        }
      }
    }
  ]
}
