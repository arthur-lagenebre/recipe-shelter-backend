{
  "info": {
    "name": "Recipe Shelter - Admin Users",
    "description": "Postman collection for admin user moderation routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "adminSessionCookie",
      "value": "PASTE_ADMIN_RS_SESSION_COOKIE_HERE"
    },
    {
      "key": "userId",
      "value": "2"
    }
  ],
  "item": [
    {
      "name": "Banned users",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users/banned",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "users",
            "banned"
          ]
        }
      }
    },
    {
      "name": "Banned users count",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users/banned/count",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "users",
            "banned",
            "count"
          ]
        }
      }
    },
    {
      "name": "Admin user profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "users",
            "{{userId}}"
          ]
        }
      }
    },
    {
      "name": "Ban user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{adminSessionCookie}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}/ban",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "users",
            "{{userId}}",
            "ban"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Repeated abuse of the platform rules.\"\n}"
        }
      }
    },
    {
      "name": "Unban user",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{adminSessionCookie}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/users/{{userId}}/unban",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "users",
            "{{userId}}",
            "unban"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Appeal accepted after moderation review.\"\n}"
        }
      }
    }
  ]
}
