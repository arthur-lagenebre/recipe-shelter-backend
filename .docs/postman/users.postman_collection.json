{
  "info": {
    "name": "Recipe Shelter - Users",
    "description": "Postman collection for public and authenticated user routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "sessionCookie",
      "value": "PASTE_RS_SESSION_COOKIE_HERE"
    },
    {
      "key": "username",
      "value": "testuser"
    },
    {
      "key": "password",
      "value": "Password123!"
    },
    {
      "key": "newPassword",
      "value": "NewPassword123!"
    }
  ],
  "item": [
    {
      "name": "Public user profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/{{username}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "{{username}}"
          ]
        }
      }
    },
    {
      "name": "Public user profile - with optional auth, includes isFavorite for published recipes",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/{{username}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "{{username}}"
          ]
        }
      }
    },
    {
      "name": "Current user profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "me"
          ]
        }
      }
    },
    {
      "name": "Update email",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"newEmail\": \"new-test@example.com\",\n  \"currentPassword\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me/email",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "me",
            "email"
          ]
        }
      }
    },
    {
      "name": "Update username",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"newUsername\": \"newtestuser\",\n  \"currentPassword\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me/username",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "me",
            "username"
          ]
        }
      }
    },
    {
      "name": "Update password",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"{{password}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me/password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "me",
            "password"
          ]
        }
      }
    },
    {
      "name": "Update password - wrong current password",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentPassword\": \"WrongPassword123!\",\n  \"newPassword\": \"Password1234!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me/password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "users",
            "me",
            "password"
          ]
        }
      }
    }
  ]
}
