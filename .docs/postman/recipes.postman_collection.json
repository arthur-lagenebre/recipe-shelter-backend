    {
      "name": "Create recipe draft - minimal",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/recipes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "recipes"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Tarte aux pommes\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('save recipe id when present', () => {",
              "  const json = pm.response.json();",
              "  if (json.id) pm.collectionVariables.set('recipeId', String(json.id));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create recipe draft - full body",
