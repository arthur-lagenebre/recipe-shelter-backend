        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Cake marbre maison\",\n  \"categoryId\": 2,\n  \"description\": \"Version brouillon pour test HTTP\",\n  \"coverImageUrl\": null,\n  \"prepTimeMinutes\": 15,\n  \"restTimeMinutes\": null,\n  \"cookTimeMinutes\": 45,\n  \"servings\": 6,\n  \"tagIds\": [1, 2],\n  \"ingredients\": [\n    {\n      \"ingredientId\": 18,\n      \"quantity\": 200,\n      \"unit\": \"g\",\n      \"note\": \"Tamisee\"\n    },\n    {\n      \"ingredientId\": 103,\n      \"quantity\": 3,\n      \"unit\": \"piece\"\n    }\n  ],\n  \"steps\": [\n    {\n      \"description\": \"Prechauffer le four a 180 degres.\"\n    },\n    {\n      \"description\": \"Melanger les ingredients puis verser dans un moule.\"\n    }\n  ],\n  \"equipments\": [\n    {\n      \"equipmentId\": 1\n    },\n    {\n      \"equipmentId\": 2\n    }\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('save recipe id when present', () => {",
              "  const json = pm.response.json();",
              "  if (json.id) pm.collectionVariables.set('recipeId', String(json.id));",
              "});"
            ]
          }
        }
      ]
