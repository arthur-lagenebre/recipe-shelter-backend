{
  "info": {
    "name": "Recipe Shelter - Admin Comments",
    "description": "Postman collection for admin comment hide, update, and hard delete routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "adminSessionCookie",
      "value": "PASTE_RS_ADMIN_SESSION_COOKIE_HERE"
    },
    {
      "key": "commentId",
      "value": "1"
    },
    {
      "key": "commentWithRepliesId",
      "value": "2"
    }
  ],
  "item": [
    {
      "name": "Moderated comments",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/moderated",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "moderated"
          ]
        }
      }
    },
    {
      "name": "Moderated comments count",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/moderated/count",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "moderated",
            "count"
          ]
        }
      }
    },
    {
      "name": "Soft deleted comments",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/soft-deleted",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "soft-deleted"
          ]
        }
      }
    },
    {
      "name": "Soft deleted comments count",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/soft-deleted/count",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "soft-deleted",
            "count"
          ]
        }
      }
    },
    {
      "name": "Hide comment as admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"reason\": \"Ce commentaire contient des attaques personnelles repetees.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/{{commentId}}/hide",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "{{commentId}}",
            "hide"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "pm.test('response is ok', () => pm.expect(pm.response.json().ok).to.eql(true));"
            ]
          }
        }
      ]
    },
    {
      "name": "Remove moderation from comment as admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/{{commentId}}/unmoderate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "{{commentId}}",
            "unmoderate"
          ]
        }
      }
    },
    {
      "name": "Restore soft deleted comment as admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/{{commentId}}/restore",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "{{commentId}}",
            "restore"
          ]
        }
      }
    },
    {
      "name": "Update comment as admin",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": null,\n  \"comment\": \"Commentaire modifie par un administrateur.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/{{commentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "{{commentId}}"
          ]
        }
      }
    },
    {
      "name": "Update comment as admin - invalid rating",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": 6,\n  \"comment\": \"Note invalide.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/{{commentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "{{commentId}}"
          ]
        }
      }
    },
    {
      "name": "Delete comment as admin - hard delete",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/{{commentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "{{commentId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "pm.test('response is ok', () => pm.expect(pm.response.json().ok).to.eql(true));"
            ]
          }
        }
      ]
    },
    {
      "name": "Delete comment as admin - has replies",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/comments/{{commentWithRepliesId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "comments",
            "{{commentWithRepliesId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 409', () => pm.response.to.have.status(409));",
              "pm.test('error code is ADMIN_COMMENTS_DELETE_HAS_REPLIES', () => {",
              "  pm.expect(pm.response.json().code).to.eql('ADMIN_COMMENTS_DELETE_HAS_REPLIES');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
