{
  "info": {
    "name": "Recipe Shelter - Favorites",
    "description": "Postman collection for favorites routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "sessionCookie",
      "value": "PASTE_RS_SESSION_COOKIE_HERE"
    },
    {
      "key": "recipeId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Add favorite",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/favorites/{{recipeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "favorites",
            "{{recipeId}}"
          ]
        }
      }
    },
    {
      "name": "My favorite recipes",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/favorites/me?page=1&limit=12",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "favorites",
            "me"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "12"
            }
          ]
        }
      }
    },
    {
      "name": "Remove favorite",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/favorites/{{recipeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "favorites",
            "{{recipeId}}"
          ]
        }
      }
    }
  ]
}
