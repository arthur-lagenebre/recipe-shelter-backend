{
  "info": {
    "name": "Recipe Shelter - Favorites",
    "description": "Postman collection for favorites routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "sessionCookie",
      "value": "PASTE_RS_APP_SESSION_COOKIE_HERE"
    },
    {
      "key": "recipeId",
      "value": "1"
    },
    {
      "key": "otherUserDraftRecipeId",
      "value": "2"
    },
    {
      "key": "notFoundRecipeId",
      "value": "999999"
    }
  ],
  "item": [
    {
      "name": "Add favorite",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/favorites/{{recipeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "favorites",
            "{{recipeId}}"
          ]
        }
      }
    },
    {
      "name": "Add favorite - recipe not visible",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/favorites/{{otherUserDraftRecipeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "favorites",
            "{{otherUserDraftRecipeId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 403', () => pm.response.to.have.status(403));",
              "pm.test('error code is RECIPES_ACCESS_DENIED', () => {",
              "  pm.expect(pm.response.json().code).to.eql('RECIPES_ACCESS_DENIED');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Add favorite - recipe not found",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/favorites/{{notFoundRecipeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "favorites",
            "{{notFoundRecipeId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 404', () => pm.response.to.have.status(404));",
              "pm.test('error code is RECIPES_NOT_FOUND', () => {",
              "  pm.expect(pm.response.json().code).to.eql('RECIPES_NOT_FOUND');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "My favorite recipes",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/favorites/me?page=1&limit=12",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "favorites",
            "me"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "12"
            }
          ]
        }
      }
    },
    {
      "name": "Remove favorite",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/favorites/{{recipeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "favorites",
            "{{recipeId}}"
          ]
        }
      }
    }
  ]
}
