{
  "info": {
    "name": "Recipe Shelter - Auth",
    "description": "Postman collection for auth routes. Login stores the rs_app_session HTTP-only cookie value in the sessionCookie collection variable when Set-Cookie is present.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "mail",
      "value": "test@example.com"
    },
    {
      "key": "username",
      "value": "testuser"
    },
    {
      "key": "password",
      "value": "Password123!"
    },
    {
      "key": "newPassword",
      "value": "NewPassword123!"
    },
    {
      "key": "resetToken",
      "value": "PASTE_RESET_TOKEN_HERE"
    },
    {
      "key": "validationToken",
      "value": "PASTE_VALIDATION_TOKEN_HERE"
    },
    {
      "key": "sessionCookie",
      "value": "PASTE_RS_APP_SESSION_COOKIE_HERE"
    }
  ],
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mail\": \"{{mail}}\",\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mail\": \"{{mail}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "pm.test('session cookie is set', () => {",
              "  const setCookie = pm.response.headers.get('Set-Cookie') || '';",
              "  const match = setCookie.match(/(?:^|,\\s*)rs_app_session=([^;]+)/);",
              "  pm.expect(match, 'rs_app_session cookie').to.not.be.null;",
              "  pm.collectionVariables.set('sessionCookie', match[1]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Validate email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{validationToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/validate-email",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "validate-email"
          ]
        }
      }
    },
    {
      "name": "Resend validation email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mail\": \"{{mail}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/resend-validation-email",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "resend-validation-email"
          ]
        }
      }
    },
    {
      "name": "Auth me",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "logout"
          ]
        }
      }
    },
    {
      "name": "Forgot password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mail\": \"{{mail}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "forgot-password"
          ]
        }
      }
    },
    {
      "name": "Forgot password - missing email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mail\": \"\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/forgot-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "forgot-password"
          ]
        }
      }
    },
    {
      "name": "Reset password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"{{newPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/reset-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "reset-password"
          ]
        }
      }
    },
    {
      "name": "Reset password - weak password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/reset-password",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "reset-password"
          ]
        }
      }
    }
  ]
}
