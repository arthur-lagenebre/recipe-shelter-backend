{
  "info": {
    "name": "Recipe Shelter - Catalog Proposals",
    "description": "Postman collection for community catalog proposal routes (tags, ingredients, equipments) and their staff review.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "sessionCookie",
      "value": "PASTE_RS_APP_SESSION_COOKIE_HERE"
    },
    {
      "key": "adminSessionCookie",
      "value": "PASTE_RS_ADMIN_SESSION_COOKIE_HERE"
    },
    {
      "key": "recipeId",
      "value": "1"
    },
    {
      "key": "otherUserRecipeId",
      "value": "2"
    },
    {
      "key": "proposalId",
      "value": "1"
    },
    {
      "key": "tagGroupId",
      "value": "1"
    },
    {
      "key": "targetTagId",
      "value": "1"
    },
    {
      "key": "targetIngredientId",
      "value": "1"
    },
    {
      "key": "targetEquipmentId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Create tag proposal",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"recipeId\": {{recipeId}},\n  \"name\": \"Sans arachide\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/catalog/tag-proposals",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "catalog",
            "tag-proposals"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', () => pm.response.to.have.status(201));",
              "pm.test('proposal is pending', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.proposalType).to.eql('tag');",
              "  pm.expect(json.status).to.eql('pending');",
              "});",
              "",
              "pm.test('save proposal id', () => {",
              "  const json = pm.response.json();",
              "  if (json.id) pm.collectionVariables.set('proposalId', String(json.id));",
              "});"
            ]
          }
        }
      ]
    },
