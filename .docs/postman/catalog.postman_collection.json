    {
      "name": "List pending catalog proposals as admin",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_admin_session={{adminSessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/admin/catalog-proposals?status=pending",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "admin",
            "catalog-proposals"
          ],
          "query": [
            {
              "key": "status",
              "value": "pending"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => pm.response.to.have.status(200));",
              "pm.test('response is paginated', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.items).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
