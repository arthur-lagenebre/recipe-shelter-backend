{
  "info": {
    "name": "Recipe Shelter - Root",
    "description": "Postman collection for root and unknown-route smoke checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Unknown route - should return 404 ROUTE_NOT_FOUND",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            ""
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 404', () => pm.response.to.have.status(404));",
              "pm.test('error code is ROUTE_NOT_FOUND', () => {",
              "  pm.expect(pm.response.json().error.code).to.eql('ROUTE_NOT_FOUND');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
