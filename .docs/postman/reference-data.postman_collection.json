{
  "info": {
    "name": "Recipe Shelter - Reference Data",
    "description": "Postman collection for categories, equipments, ingredients, and tags routes. Ingredient and tag responses include canonical identity, lifecycle, and audit timestamps; tags also include their group.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "sessionCookie",
      "value": "PASTE_RS_APP_SESSION_COOKIE_HERE"
    },
    {
      "key": "categoryId",
      "value": "1"
    },
    {
      "key": "equipmentId",
      "value": "1"
    },
    {
      "key": "ingredientId",
      "value": "1"
    },
    {
      "key": "tagId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Categories",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/categories",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "categories"
          ]
        }
      }
    },
    {
      "name": "Category by id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/categories/{{categoryId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "categories",
            "{{categoryId}}"
          ]
        }
      }
    },
    {
      "name": "Equipments",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/equipments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "equipments"
          ]
        }
      }
    },
    {
      "name": "Equipment by id",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/equipments/{{equipmentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "equipments",
            "{{equipmentId}}"
          ]
        }
      }
    },
    {
      "name": "Ingredients",
      "description": "Returns active canonical ingredients with their normalized identity, lifecycle, and audit timestamps.",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/ingredients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "ingredients"
          ]
        }
      }
    },
    {
      "name": "Ingredient by id",
      "description": "Returns an ingredient by id, including deprecated or merged historical entries and their canonical merge target.",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/ingredients/{{ingredientId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "ingredients",
            "{{ingredientId}}"
          ]
        }
      }
    },
    {
      "name": "Tags",
      "description": "Returns active tags with canonical identity, lifecycle, audit timestamps, and their group.",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/tags",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "tags"
          ]
        }
      }
    },
    {
      "name": "Tag by id",
      "description": "Returns one tag with its group.",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/tags/{{tagId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "tags",
            "{{tagId}}"
          ]
        }
      }
    }
  ]
}
