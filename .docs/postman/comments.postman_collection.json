{
  "info": {
    "name": "Recipe Shelter - Comments",
    "description": "Postman collection for testing comments routes. Set collection variables before running authenticated requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "sessionCookie",
      "value": "PASTE_RS_APP_SESSION_COOKIE_HERE"
    },
    {
      "key": "recipeId",
      "value": "1"
    },
    {
      "key": "commentId",
      "value": "1"
    },
    {
      "key": "parentCommentId",
      "value": "1"
    },
    {
      "key": "recipeSlug",
      "value": "cake-marbre-maison"
    }
  ],
  "item": [
    {
      "name": "Recipe comments - public",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/recipes/{{recipeId}}/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "recipes",
            "{{recipeId}}",
            "comments"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('response is an array', () => {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Published recipe detail with comment tree - public",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/recipes/{{recipeSlug}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "recipes",
            "{{recipeSlug}}"
          ]
        }
      }
    },
    {
      "name": "Recipe comments - bad recipe id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/recipes/abc/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "recipes",
            "abc",
            "comments"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 400', () => {",
              "  pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('error code is COMMENTS_BAD_RECIPE_ID', () => {",
              "  pm.expect(pm.response.json().code).to.eql('COMMENTS_BAD_RECIPE_ID');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create root comment with rating",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/recipes/{{recipeId}}/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "recipes",
            "{{recipeId}}",
            "comments"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Super recette, facile a suivre.\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', () => {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('response contains created comment', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.id).to.exist;",
              "  pm.expect(json.recipeId).to.eql(Number(pm.collectionVariables.get('recipeId')));",
              "  pm.expect(json.rating).to.eql(5);",
              "  pm.expect(json.comment).to.eql('Super recette, facile a suivre.');",
              "});",
              "",
              "pm.test('save comment id', () => {",
              "  const json = pm.response.json();",
              "  if (json.id) pm.collectionVariables.set('commentId', String(json.id));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Create reply without rating",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "rs_app_session={{sessionCookie}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/recipes/{{recipeId}}/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "recipes",
            "{{recipeId}}",
            "comments"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"parentCommentId\": {{parentCommentId}},\n  \"comment\": \"Merci pour l'astuce.\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', () => {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('response contains reply', () => {",
              "  const json = pm.response.json();",
              "  pm.expect(json.parentCommentId).to.eql(Number(pm.collectionVariables.get('parentCommentId')));",
              "  pm.expect(json.comment).to.eql(\"Merci pour l'astuce.\");",
              "});"
            ]
          }
        }
      ]
    },
